{
  "family": "medgraph-ai",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "medgraph-ai",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/medgraph-ai:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://localhost:3000/ || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 10
      },
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "3000" },
        { "name": "HOSTNAME", "value": "0.0.0.0" },
        {
          "name": "NEXT_PUBLIC_WORKOS_REDIRECT_URI",
          "value": "https://your-production-domain.com/auth/callback"
        }
      ],
      "secrets": [
        {
          "name": "WORKOS_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:medgraph/workos:WORKOS_API_KEY::"
        },
        {
          "name": "WORKOS_CLIENT_ID",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:medgraph/workos:WORKOS_CLIENT_ID::"
        },
        {
          "name": "WORKOS_COOKIE_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:medgraph/workos:WORKOS_COOKIE_PASSWORD::"
        },
        {
          "name": "OPENAI_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:medgraph/ai:OPENAI_API_KEY::"
        },
        {
          "name": "HF_TOKEN",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:medgraph/ai:HF_TOKEN::"
        },
        {
          "name": "HF_ENDPOINT_URL",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:medgraph/ai:HF_ENDPOINT_URL::"
        },
        {
          "name": "HF_MODEL_ID",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:medgraph/ai:HF_MODEL_ID::"
        },
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:medgraph/db:DATABASE_URL::"
        },
        {
          "name": "NEO4J_URI",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:medgraph/neo4j:NEO4J_URI::"
        },
        {
          "name": "NEO4J_USERNAME",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:medgraph/neo4j:NEO4J_USERNAME::"
        },
        {
          "name": "NEO4J_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:medgraph/neo4j:NEO4J_PASSWORD::"
        },
        {
          "name": "NEO4J_DATABASE",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:medgraph/neo4j:NEO4J_DATABASE::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/medgraph-ai",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}

