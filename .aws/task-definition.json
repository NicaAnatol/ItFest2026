{
  "family": "medgraph-ai",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::650080740856:role/service-role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::650080740856:role/service-role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "medgraph-ai",
      "image": "650080740856.dkr.ecr.us-east-1.amazonaws.com/medgraph-ai:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "wget --no-verbose --tries=1 --spider http://localhost:3000/api/health || exit 1"],
        "interval": 30,
        "timeout": 10,
        "retries": 5,
        "startPeriod": 120
      },
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "3000" },
        {
          "name": "NEXT_PUBLIC_WORKOS_REDIRECT_URI",
          "value": "https://medgraph.vulniq.org/auth/callback"
        }
      ],
      "secrets": [
        {
          "name": "WORKOS_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:650080740856:secret:medgraph/workos:WORKOS_API_KEY::"
        },
        {
          "name": "WORKOS_CLIENT_ID",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:650080740856:secret:medgraph/workos:WORKOS_CLIENT_ID::"
        },
        {
          "name": "WORKOS_COOKIE_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:650080740856:secret:medgraph/workos:WORKOS_COOKIE_PASSWORD::"
        },
        {
          "name": "OPENAI_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:650080740856:secret:medgraph/ai:OPENAI_API_KEY::"
        },
        {
          "name": "HF_TOKEN",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:650080740856:secret:medgraph/ai:HF_TOKEN::"
        },
        {
          "name": "HF_ENDPOINT_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:650080740856:secret:medgraph/ai:HF_ENDPOINT_URL::"
        },
        {
          "name": "HF_MODEL_ID",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:650080740856:secret:medgraph/ai:HF_MODEL_ID::"
        },
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:650080740856:secret:medgraph/db:DATABASE_URL::"
        },
        {
          "name": "NEO4J_URI",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:650080740856:secret:medgraph/neo4j:NEO4J_URI::"
        },
        {
          "name": "NEO4J_USERNAME",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:650080740856:secret:medgraph/neo4j:NEO4J_USERNAME::"
        },
        {
          "name": "NEO4J_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:650080740856:secret:medgraph/neo4j:NEO4J_PASSWORD::"
        },
        {
          "name": "NEO4J_DATABASE",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:650080740856:secret:medgraph/neo4j:NEO4J_DATABASE::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/medgraph-ai",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}

